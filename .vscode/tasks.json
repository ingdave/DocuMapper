{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm install",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "problemMatcher": ["$npm"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true
      }
    },
    {
      "label": "Start Server (port 3000)",
      "type": "shell",
      "command": "npm",
      "args": ["start"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Server running.*$",
          "endsPattern": "^.*Server running.*$"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      }
    },
    {
      "label": "Open in Browser",
      "type": "shell",
      "command": "start",
      "args": ["http://localhost:3000"],
      "windows": {
        "command": "start",
        "args": ["http://localhost:3000"]
      },
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
